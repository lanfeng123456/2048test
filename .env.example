# PostgreSQL connection string (Neon / Supabase / Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth 2.0 Web client credentials (Google Cloud Console > APIs & Services > Credentials)
# Authorized redirect URI must include: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Creem payments (https://creem.io) — create a monthly and a yearly subscription product.
# CREEM_TEST_MODE=true uses the sandbox API (test-api.creem.io); set to "false" for live.
CREEM_TEST_MODE="true"
CREEM_API_KEY="creem_test_xxx"
# Webhook signing secret: Creem dashboard > Developers > Webhooks. Endpoint URL:
#   http://localhost:3000/api/webhook/creem   (use a public tunnel URL in dev, e.g. ngrok)
CREEM_WEBHOOK_SECRET="whsec_xxx"
CREEM_PRODUCT_ID_MONTHLY="prod_monthly_xxx"
CREEM_PRODUCT_ID_YEARLY="prod_yearly_xxx"
